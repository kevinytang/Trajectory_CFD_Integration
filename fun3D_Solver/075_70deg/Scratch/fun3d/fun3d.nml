&project
    project_rootname = '075_70deg'
/

&raw_grid
    grid_format = 'AFLR3'
    data_format = 'stream'
/

&nonlinear_solver_parameters
    schedule_cfl = 0.1, 10.0
    schedule_iteration = 1, 6000
/

&code_run_control
    steps = 6000
    restart_read = 'off'
/

&boundary_conditions
/
&reference_physical_properties
  dim_input_type = 'nondimensional'
  temperature_units = 'Kelvin'
  gridlength_conversion = 1.0
  mach_number = 21.294442514093646
  temperature = 234.881591796875
  angle_of_attack = -2.2721541053633727
  angle_of_yaw = 0.0
/

&governing_equations
  eqn_type = 'cal_perf_compress'
  viscous_terms = 'inviscid'
/

&inviscid_flux_method
  flux_construction = 'dldfss'
  flux_limiter = 'hvanalbada'
  first_order_iterations = 2000
  freeze_limiter_iteration = 4000
/

&nonlinear_solver_parameters
  schedule_iteration = 1 6000
  schedule_cfl = 0.1 10.0
/

&force_moment_integ_properties
  area_reference = 12.566370614359172
/

&linear_solver_control
  linear_projection = .true.
/

